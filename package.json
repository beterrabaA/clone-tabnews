{
  "name": "clone-tabenews",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24"
  },
  "type": "module",
  "scripts": {
    "dev": "npm run services:run && npm run migration:up && next dev --turbopack",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:run": "npm run services:up && npm run wait-for-postgres",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "test": "npm run services:run && concurrently -n next,jest --hide next -k -s command-jest \"next dev\" \"jest --runInBand\"",
    "test:watch": "jest --watchAll --runInBand",
    "migration:create": "node-pg-migrate -m infra/migrations create",
    "migration:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "wait-for-postgres": "node infra/scripts/wait-for-postgres.js"
  },
  "license": "MIT",
  "author": {
    "name": "Lucas Vieira",
    "email": "ls6182315@gmail.com",
    "url": "https://github.com/beterrabaA"
  },
  "dependencies": {
    "async-retry": "^1.3.3",
    "dotenv": "^16.5.0",
    "next": "15.1.3",
    "node-pg-migrate": "^7.9.1",
    "pg": "8.13.1",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "9.17.0",
    "eslint-config-next": "15.1.3",
    "jest": "^29.7.0",
    "postcss": "8.4.49",
    "prettier": "3.4.2",
    "tailwindcss": "3.4.17"
  }
}
